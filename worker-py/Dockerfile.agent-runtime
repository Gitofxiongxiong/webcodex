FROM node:22-bookworm

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    file \
    git \
    jq \
    poppler-utils \
    python3 \
    python3-pil \
    python3-pip \
    ripgrep \
    chromium \
    tini \
    fonts-dejavu \
    fonts-liberation \
    fonts-noto-cjk \
  && corepack enable \
  && useradd --create-home --shell /bin/bash --uid 10001 codex \
  && mkdir -p /workspace /sandbox /artifacts \
  && chown -R codex:codex /workspace /sandbox /artifacts /home/codex \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /sandbox
USER codex

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["sleep", "infinity"]
