DATABASE_URL=sqlite:///../data/webcodex_demo.db
API_BASE_URL=http://127.0.0.1:8000
WORKER_TOKEN=dev-worker-token
NODE_WORKER_ENTRY=../worker-node/src/worker.mjs
WORKER_SANDBOX_ROOT=../data/sandboxes
WORKER_RUNS_ROOT=../data/runs
WORKER_RUNTIME=docker
WORKER_DOCKER_IMAGE=webcodex-agent-runtime:latest
WORKER_DOCKER_AUTO_BUILD=true
WORKER_DOCKER_NETWORK=bridge
WORKER_DOCKER_CPUS=2
WORKER_DOCKER_MEMORY=4g
WORKER_DOCKER_PIDS_LIMIT=512
WORKER_KEEP_CONTAINER=false
WORKER_KEEP_RUN_DIR=true
WORKER_RUNTIME_TOOL_MODE=auto
OPENAI_API_KEY=your-new-api-key
OPENAI_BASE_URL=
OPENAI_API_PROTOCOL=responses
OPENAI_PROVIDER_PROFILE=auto
OPENAI_RESPONSES_RELAY_MODE=auto
OPENAI_SEND_SERVICE_TIER=auto
OPENAI_MODEL=gpt-5.5
OPENAI_COMPACTION_ENABLED=true
OPENAI_REASONING_EFFORT=xhigh
OPENAI_REASONING_SUMMARY=detailed
OPENAI_TEXT_VERBOSITY=low
OPENAI_SERVICE_TIER=priority
OPENAI_STORE=false
OPENAI_AGENTS_DISABLE_TRACING=1
CODEX_RELAY_ENABLED=false
CODEX_RELAY_API_KEY=your-local-relay-token
CODEX_RELAY_AUTH_FILE=../docs/auth.json
CODEX_RELAY_MODEL=gpt-5.5
CODEX_RELAY_UPSTREAM_BASE_URL=https://chatgpt.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_BUCKET_NAME=your-oss-bucket
OSS_KEY_PREFIX=your-fixed-prefix
